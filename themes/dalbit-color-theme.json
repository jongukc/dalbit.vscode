  "tokenColors": [
    {
      "settings": { "foreground": "#ced0d6" }
    },
    {
      "name": "Comment",
      "scope": "comment, punctuation.definition.comment",
      "settings": { "foreground": "#9e988c", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": "string, punctuation.definition.string.begin, punctuation.definition.string.end, punctuation.definition.string.template.begin, punctuation.definition.string.template.end",
      "settings": { "foreground": "#74bc42" }
    },
    {
      "name": "String escape",
      "scope": "constant.character.escape, punctuation.section.embedded, punctuation.definition.template-expression, variable.interpolation, storage.type.format, constant.other.placeholder",
      "settings": { "foreground": "#d07878" }
    },
    {
      "name": "Regex",
      "scope": "string.regexp, constant.regexp",
      "settings": { "foreground": "#70c8bc" }
    },
    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": { "foreground": "#4fa8a0" }
    },
    {
      "name": "Boolean / language constant",
      "scope": "constant.language.boolean, constant.language.null, constant.language.undefined, constant.language.nan",
      "settings": { "foreground": "#bc6838", "fontStyle": "bold" }
    },
    {
      "name": "Constant",
      "scope": "constant, support.constant, constant.language",
      "settings": { "foreground": "#bc6838" }
    },
    {
      "name": "Keyword",
      "scope": "keyword, storage.type.function, storage.type.class, storage.type.enum, storage.type.interface, storage.type.property, keyword.operator.new, keyword.operator.expression, keyword.operator.delete, keyword.control, storage.type.extends",
      "settings": { "foreground": "#bc6838", "fontStyle": "bold" }
    },
    {
      "name": "Storage",
      "scope": "storage, modifier, keyword.var",
      "settings": { "foreground": "#bc6838", "fontStyle": "bold" }
    },
    {
      "name": "Exception",
      "scope": "keyword.control.trycatch, keyword.control.exception",
      "settings": { "foreground": "#e04a2a", "fontStyle": "bold" }
    },
    {
      "name": "Operator",
      "scope": "keyword.operator",
      "settings": { "foreground": "#b8bac0" }
    },
    {
      "name": "Function",
      "scope": "entity.name.function, support.function, meta.function-call, meta.definition.method",
      "settings": { "foreground": "#edc14a" }
    },
    {
      "name": "Type",
      "scope": "entity.name.type, support.type, keyword.type, entity.name.type.class, support.class, entity.other.inherited-class",
      "settings": { "foreground": "#d9a82e" }
    },
    {
      "name": "Constructor",
      "scope": "entity.name.function.constructor",
      "settings": { "foreground": "#d9a82e" }
    },
    {
      "name": "Preprocessor / import",
      "scope": "keyword.control.import, keyword.control.export, keyword.control.from, keyword.control.directive, keyword.preprocessor, punctuation.definition.preprocessor, keyword.other.import, keyword.other.package, entity.name.function.preprocessor",
      "settings": { "foreground": "#d07878" }
    },
    {
      "name": "Annotation / decorator",
      "scope": "storage.type.annotation, punctuation.decorator, meta.decorator",
      "settings": { "foreground": "#d07878" }
    },
    {
      "name": "Namespace / module",
      "scope": "entity.name.type.namespace, entity.name.scope-resolution, entity.name.type.module, support.module",
      "settings": { "foreground": "#b8bac0" }
    },
    {
      "name": "Variable",
      "scope": "variable, support.variable, meta.definition.variable",
      "settings": { "foreground": "#ced0d6" }
    },
    {
      "name": "Parameter",
      "scope": "variable.parameter",
      "settings": { "foreground": "#b8bac0" }
    },
    {
      "name": "Variable builtin (self/this)",
      "scope": "variable.language.this, variable.language.self, variable.language.super, keyword.other.this, variable.language.special",
      "settings": { "foreground": "#d07878", "fontStyle": "italic" }
    },
    {
      "name": "Property / field",
      "scope": "variable.object.property, support.variable.property, variable.other.property, variable.other.object.property, variable.other.enummember, variable.other.member, meta.object-literal.key",
      "settings": { "foreground": "#7eb0cc" }
    },
    {
      "name": "Tag",
      "scope": "entity.name.tag",
      "settings": { "foreground": "#4fa8a0" }
    },
    {
      "name": "Tag attribute",
      "scope": "entity.other.attribute-name",
      "settings": { "foreground": "#d9a82e" }
    },
    {
      "name": "Delimiter / punctuation",
      "scope": "punctuation, meta.brace, meta.delimiter, meta.bracket",
      "settings": { "foreground": "#909298" }
    },
    {
      "name": "Tag delimiter",
      "scope": "punctuation.definition.tag.begin, punctuation.definition.tag.end, punctuation.definition.tag",
      "settings": { "foreground": "#909298" }
    },
    {
      "name": "Markdown heading",
      "scope": "heading.1.markdown, heading.2.markdown, heading.3.markdown, heading.4.markdown, heading.5.markdown, heading.6.markdown, markup.heading",
      "settings": { "foreground": "#edc14a", "fontStyle": "bold" }
    },
    {
      "name": "Markdown heading delimiter",
      "scope": "punctuation.definition.heading.markdown",
      "settings": { "foreground": "#9e988c" }
    },
    {
      "name": "Markdown link",
      "scope": "string.other.link.title.markdown, constant.other.reference.link.markdown, string.other.link.description.markdown",
      "settings": { "foreground": "#7eb0cc" }
    },
    {
      "name": "Markdown link URL",
      "scope": "markup.underline.link.image.markdown, markup.underline.link.markdown",
      "settings": { "foreground": "#7eb0cc", "fontStyle": "underline" }
    },
    {
      "name": "Markdown code",
      "scope": "markup.fenced_code.block.markdown, markup.inline.raw.string.markdown, markup.raw",
      "settings": { "foreground": "#74bc42" }
    },
    {
      "name": "Markdown bold",
      "scope": "markup.bold",
      "settings": { "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": "markup.italic",
      "settings": { "fontStyle": "italic" }
    },
    {
      "name": "Markdown quote",
      "scope": "markup.quote.markdown",
      "settings": { "foreground": "#909298", "fontStyle": "italic" }
    },
    {
      "name": "Markdown list mark",
      "scope": "punctuation.definition.list.begin.markdown",
      "settings": { "foreground": "#bc6838" }
    },
    {
      "name": "CSS property",
      "scope": "support.type.property-name.css, support.type.property-name.scss, support.type.property-name.less",
      "settings": { "foreground": "#7eb0cc" }
    },
    {
      "name": "CSS selector / tag",
      "scope": "entity.name.tag.css, meta.selector.css",
      "settings": { "foreground": "#d07878" }
    },
    {
      "name": "CSS pseudo",
      "scope": "entity.other.attribute-name.pseudo-class.css, entity.other.attribute-name.pseudo-element.css",
      "settings": { "foreground": "#d9a82e" }
    },
    {
      "name": "CSS unit",
      "scope": "keyword.other.unit",
      "settings": { "foreground": "#bc6838" }
    },
    {
      "name": "JSON key",
      "scope": "support.type.property-name.json",
      "settings": { "foreground": "#7eb0cc" }
    },
    {
      "name": "TOML table",
      "scope": "entity.other.attribute-name.table.toml, punctuation.definition.table.toml, entity.other.attribute-name.table.array.toml",
      "settings": { "foreground": "#d07878" }
    },
    {
      "name": "YAML key",
      "scope": "entity.name.tag.yaml",
      "settings": { "foreground": "#7eb0cc" }
    },
    {
      "name": "LaTeX command",
      "scope": "support.function.be.latex",
      "settings": { "foreground": "#e04a2a" }
    },
    {
      "name": "LaTeX section",
      "scope": "support.function.section.latex",
      "settings": { "foreground": "#bc6838" }
    },
    {
      "name": "LaTeX argument",
      "scope": "support.class.latex, variable.parameter.latex, variable.parameter.function.latex",
      "settings": { "foreground": "#d9a82e" }
    },
    {
      "name": "Todo",
      "scope": "keyword.todo, keyword.other.todo",
      "settings": { "foreground": "#edc14a", "fontStyle": "bold" }
    }
  ],

  "semanticTokenColors": {
